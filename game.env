# Single place for the identity of this game. All build/deploy scripts
# source this file. When you fork GameBase for a new game, edit these
# values (and the matching values in Cargo.toml / gradle files listed in
# README.md "Making it yours").

# Rust crate name = native library name = exe name (must match Cargo.toml [lib]/[[bin]] name)
GAME_NAME="game_base"

# Android application id used by the cargo-apk path (must match
# [package.metadata.android] package in Cargo.toml)
ANDROID_PACKAGE="com.gamebase.game"

# Android application id used by the Gradle path (must match
# applicationId/namespace in app/build.gradle)
GRADLE_PACKAGE="org.gamebase.game_base"

# Android SDK locations
export ANDROID_HOME=$HOME/android-sdk
export ANDROID_AVD_HOME=$HOME/.config/.android/avd
export ANDROID_NDK_HOME=$ANDROID_HOME/ndk/26.1.10909125
export ANDROID_NDK_ROOT=$ANDROID_NDK_HOME
export PATH=$PATH:$ANDROID_HOME/platform-tools:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/emulator:$HOME/.cargo/bin
